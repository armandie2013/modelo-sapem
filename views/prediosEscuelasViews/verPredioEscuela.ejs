<div class="min-h-[calc(100vh-240px)] px-2 sm:px-4 py-2 sm:py-4 safe-bottom">
  <div class="mx-auto max-w-6xl">

    <div class="bg-white border border-gray-200 rounded-2xl shadow-xl overflow-hidden">
      <div class="px-4 sm:px-6 py-4 border-b border-gray-200 bg-gradient-to-r from-blue-50 via-white to-white">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
          <div class="min-w-0">
            <h1 class="text-xl sm:text-2xl font-extrabold tracking-tight text-gray-900">
              Ver Predio Escuela
            </h1>
            <p class="mt-0.5 text-xs sm:text-sm text-gray-600">
              Información completa del registro.
            </p>
          </div>

          <div class="hidden sm:block">
            <a
              href="/predios-escuelas/dashboard"
              class="inline-flex items-center justify-center rounded-xl bg-gray-100 border border-gray-300 px-4 py-2 text-sm font-semibold text-gray-700 hover:bg-gray-200 transition focus:outline-none focus:ring-2 focus:ring-blue-500/30"
            >
              Volver
            </a>
          </div>
        </div>
      </div>

      <div class="px-4 sm:px-6 py-4">
        <% const inputReadonly = "w-full rounded-xl border border-gray-300 bg-gray-50 px-3 py-1.5 text-sm text-gray-700"; %>

        <section class="rounded-2xl border border-gray-200 bg-white p-4">
          <div class="mb-3">
            <h2 class="text-sm font-extrabold text-gray-900">Datos del establecimiento</h2>
            <p class="text-xs text-gray-600">Detalle general de la escuela.</p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-12 gap-3">
            <div class="md:col-span-2">
              <label class="block text-xs font-medium text-gray-700 mb-1">Predio</label>
              <input type="text" value="<%= predioEscuela.predio %>" class="<%= inputReadonly %>" disabled>
            </div>

            <div class="md:col-span-3">
              <label class="block text-xs font-medium text-gray-700 mb-1">CUE</label>
              <input type="text" value="<%= predioEscuela.cue %>" class="<%= inputReadonly %>" disabled>
            </div>

            <div class="md:col-span-7">
              <label class="block text-xs font-medium text-gray-700 mb-1">Nombre de la escuela</label>
              <input type="text" value="<%= predioEscuela.nombreEscuela %>" class="<%= inputReadonly %>" disabled>
            </div>

            <div class="md:col-span-6">
              <label class="block text-xs font-medium text-gray-700 mb-1">Dirección</label>
              <input type="text" value="<%= predioEscuela.direccion %>" class="<%= inputReadonly %>" disabled>
            </div>

            <div class="md:col-span-3">
              <label class="block text-xs font-medium text-gray-700 mb-1">Ciudad</label>
              <input type="text" value="<%= predioEscuela.ciudad %>" class="<%= inputReadonly %>" disabled>
            </div>

            <div class="md:col-span-3">
              <label class="block text-xs font-medium text-gray-700 mb-1">Departamento</label>
              <input type="text" value="<%= predioEscuela.departamento %>" class="<%= inputReadonly %>" disabled>
            </div>

            <div class="md:col-span-3">
              <label class="block text-xs font-medium text-gray-700 mb-1">Megabytes asignados</label>
              <input type="text" value="<%= predioEscuela.megabytesAsignados %>" class="<%= inputReadonly %>" disabled>
            </div>

            <div class="md:col-span-5">
              <label class="block text-xs font-medium text-gray-700 mb-1">ISP</label>
              <input type="text" value="<%= predioEscuela.isp %>" class="<%= inputReadonly %>" disabled>
            </div>

            <div class="md:col-span-4">
              <label class="block text-xs font-medium text-gray-700 mb-1">Tecnología</label>
              <input type="text" value="<%= predioEscuela.tecnologia %>" class="<%= inputReadonly %>" disabled>
            </div>
          </div>
        </section>
      </div>
    </div>
  </div>
</div>