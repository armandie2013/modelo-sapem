<%
  const mensajeSeguro = typeof mensaje !== 'undefined' ? mensaje : '';
  const prediosSeguro = typeof prediosEscuelas !== 'undefined' ? prediosEscuelas : [];

  const formatearCueEnBloques = (cue) => {
    const limpio = String(cue || '').replace(/[^0-9]/g, '');
    const bloques = [];

    for (let i = 0; i < limpio.length; i += 9) {
      const bloque = limpio.slice(i, i + 9);
      if (bloque) bloques.push(bloque);
    }

    return bloques;
  };

  const normalizarTextoVista = (valor) => {
    return String(valor || '').trim();
  };

  const obtenerValoresUnicos = (campo) => {
    return [...new Set(
      prediosSeguro
        .map((item) => normalizarTextoVista(item?.[campo]))
        .filter((valor) => valor !== '')
    )].sort((a, b) => a.localeCompare(b, 'es', { sensitivity: 'base' }));
  };

  const departamentosUnicos = obtenerValoresUnicos('departamento');
  const ciudadesUnicas = obtenerValoresUnicos('ciudad');
  const ispUnicos = obtenerValoresUnicos('isp');
  const tecnologiasUnicas = obtenerValoresUnicos('tecnologia');

  const megabytesUnicos = [...new Set(
    prediosSeguro
      .map((item) => Number(item?.megabytesAsignados || 0))
      .filter((valor) => !Number.isNaN(valor))
  )].sort((a, b) => a - b);
%>

<main class="bg-gray-100 pt-0 pb-4 px-2 sm:px-3 lg:px-4">
  <div class="w-full max-w-[95vw] 2xl:max-w-[1500px] mx-auto bg-white p-3 sm:p-3.5 xl:p-5 rounded-2xl shadow-xl border border-gray-300">

    <!-- ===== Encabezado + CTA ===== -->
    <div class="flex flex-col gap-2 md:flex-row md:items-start md:justify-between">
      <div class="min-w-0">
        <h1 class="text-lg sm:text-xl xl:text-2xl font-extrabold tracking-tight text-gray-900 leading-tight">
          Predios Escuelas
        </h1>
        <p class="mt-0.5 text-xs xl:text-sm text-gray-600 leading-tight">
          Listado general de predios y conectividad asignada.
        </p>
      </div>

      <a
        href="/predios-escuelas/crear"
        class="inline-flex items-center justify-center rounded-xl bg-blue-600 px-3 sm:px-4 py-1.5 sm:py-2 text-xs sm:text-sm font-semibold text-white
               hover:bg-blue-700 transition focus:outline-none focus:ring-2 focus:ring-blue-500/30 self-start"
      >
        Nuevo registro
      </a>
    </div>

    <% if (mensajeSeguro) { %>
      <div class="mt-3 rounded-xl border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-800 shadow-sm">
        <%= mensajeSeguro %>
      </div>
    <% } %>

    <!-- ===== FILTROS ===== -->
    <section class="mt-3 rounded-2xl border border-gray-200 bg-gray-50 p-3 shadow-sm">
      <div class="flex flex-col gap-2 xl:flex-row xl:items-end xl:justify-between">

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-7 gap-2 flex-1">

          <div class="sm:col-span-2 lg:col-span-2">
            <label for="filtroBuscar" class="block text-[11px] font-semibold text-gray-600 mb-1">
              Buscar
            </label>
            <input
              type="text"
              id="filtroBuscar"
              placeholder="Predio, CUE, escuela, ciudad, ISP..."
              class="w-full rounded-xl border border-gray-300 bg-white px-3 py-2 text-xs text-gray-800 outline-none
                     focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20"
            >
          </div>

          <div>
            <label for="filtroDepartamento" class="block text-[11px] font-semibold text-gray-600 mb-1">
              Departamento
            </label>
            <select
              id="filtroDepartamento"
              class="w-full rounded-xl border border-gray-300 bg-white px-2 py-2 text-xs text-gray-800 outline-none
                     focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20"
            >
              <option value="">Todos</option>
              <% departamentosUnicos.forEach((departamento) => { %>
                <option value="<%= departamento %>"><%= departamento %></option>
              <% }) %>
            </select>
          </div>

          <div>
            <label for="filtroCiudad" class="block text-[11px] font-semibold text-gray-600 mb-1">
              Ciudad
            </label>
            <select
              id="filtroCiudad"
              class="w-full rounded-xl border border-gray-300 bg-white px-2 py-2 text-xs text-gray-800 outline-none
                     focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20"
            >
              <option value="">Todas</option>
              <% ciudadesUnicas.forEach((ciudad) => { %>
                <option value="<%= ciudad %>"><%= ciudad %></option>
              <% }) %>
            </select>
          </div>

          <div>
            <label for="filtroIsp" class="block text-[11px] font-semibold text-gray-600 mb-1">
              ISP
            </label>
            <select
              id="filtroIsp"
              class="w-full rounded-xl border border-gray-300 bg-white px-2 py-2 text-xs text-gray-800 outline-none
                     focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20"
            >
              <option value="">Todos</option>
              <% ispUnicos.forEach((isp) => { %>
                <option value="<%= isp %>"><%= isp %></option>
              <% }) %>
            </select>
          </div>

          <div>
            <label for="filtroTecnologia" class="block text-[11px] font-semibold text-gray-600 mb-1">
              Tecnología
            </label>
            <select
              id="filtroTecnologia"
              class="w-full rounded-xl border border-gray-300 bg-white px-2 py-2 text-xs text-gray-800 outline-none
                     focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20"
            >
              <option value="">Todas</option>
              <% tecnologiasUnicas.forEach((tecnologia) => { %>
                <option value="<%= tecnologia %>"><%= tecnologia %></option>
              <% }) %>
            </select>
          </div>

          <div>
            <label for="filtroMb" class="block text-[11px] font-semibold text-gray-600 mb-1">
              MB
            </label>
            <select
              id="filtroMb"
              class="w-full rounded-xl border border-gray-300 bg-white px-2 py-2 text-xs text-gray-800 outline-none
                     focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20"
            >
              <option value="">Todos</option>
              <% megabytesUnicos.forEach((mb) => { %>
                <option value="<%= mb %>"><%= mb %> MB</option>
              <% }) %>
            </select>
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-1 gap-2 xl:min-w-[180px]">
          <button
            type="button"
            id="btnLimpiarFiltros"
            class="inline-flex items-center justify-center rounded-xl border border-gray-300 bg-white px-3 py-2 text-xs font-semibold text-gray-700
                   hover:bg-gray-100 transition"
          >
            Limpiar filtros
          </button>

          <div class="inline-flex items-center justify-center rounded-xl border border-blue-200 bg-blue-50 px-3 py-2 text-xs font-semibold text-blue-800">
            <span id="contadorFiltros" data-total="<%= prediosSeguro.length %>">
              Mostrando <%= prediosSeguro.length %> de <%= prediosSeguro.length %>
            </span>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== DESKTOP / TABLE ===== -->
    <div class="mt-2 hidden sm:block">
      <div class="overflow-x-auto rounded-2xl border border-gray-200">
        <table class="w-full table-fixed border-collapse min-w-[1180px] xl:min-w-[1260px] text-[10px] lg:text-[11px] xl:text-xs">
          <thead class="bg-gray-50 text-gray-700 font-semibold">
            <tr>
              <th class="w-[45px] px-2 py-1.5 text-left">N°</th>
              <th class="w-[60px] px-2 py-1.5 text-left">Predio</th>
              <th class="w-[75px] px-2 py-1.5 text-left">CUE</th>
              <th class="w-[320px] px-2 py-1.5 text-left">Escuela</th>
              <th class="w-[250px] px-2 py-1.5 text-left">Dirección</th>
              <th class="w-[110px] px-2 py-1.5 text-left">Ciudad</th>
              <th class="w-[120px] px-2 py-1.5 text-left">Departamento</th>
              <th class="w-[58px] px-2 py-1.5 text-center">MB</th>
              <th class="w-[100px] px-2 py-1.5 text-left">ISP</th>
              <th class="w-[90px] px-2 py-1.5 text-left">Tecnología</th>
              <th class="w-[168px] px-2 py-1.5 text-center">Acciones</th>
            </tr>
          </thead>

          <tbody class="bg-white">
            <% if (!prediosSeguro || prediosSeguro.length === 0) { %>
              <tr class="border-t">
                <td colspan="11" class="px-4 py-6 text-center text-sm text-gray-500">
                  No hay registros cargados.
                </td>
              </tr>
            <% } else { %>
              <tr id="filaSinResultadosTabla" class="border-t hidden">
                <td colspan="11" class="px-4 py-6 text-center text-sm text-gray-500">
                  No hay registros que coincidan con los filtros.
                </td>
              </tr>

              <% prediosSeguro.forEach((predioEscuela, index) => { %>
                <%
                  const textoBusqueda = [
                    predioEscuela.predio,
                    predioEscuela.cue,
                    predioEscuela.nombreEscuela,
                    predioEscuela.direccion,
                    predioEscuela.ciudad,
                    predioEscuela.departamento,
                    predioEscuela.megabytesAsignados,
                    predioEscuela.isp,
                    predioEscuela.tecnologia
                  ].join(' ');
                %>

                <tr
                  class="border-t hover:bg-blue-50/40 transition align-top fila-predio"
                  data-search="<%= textoBusqueda %>"
                  data-departamento="<%= predioEscuela.departamento || '' %>"
                  data-ciudad="<%= predioEscuela.ciudad || '' %>"
                  data-isp="<%= predioEscuela.isp || '' %>"
                  data-tecnologia="<%= predioEscuela.tecnologia || '' %>"
                  data-mb="<%= predioEscuela.megabytesAsignados || 0 %>"
                >
                  <td class="px-2 py-2 whitespace-nowrap font-extrabold text-blue-800 align-top">
                    <span class="numero-visible inline-flex items-center rounded-lg border border-blue-200 bg-blue-50 px-1.5 py-0.5">
                      #<%= index + 1 %>
                    </span>
                  </td>

                  <td class="px-2 py-2 whitespace-nowrap overflow-hidden text-ellipsis align-top">
                    <%= predioEscuela.predio %>
                  </td>

                  <td class="px-2 py-2 align-top">
                    <div class="flex flex-col gap-0 leading-tight">
                      <% const cueBloques = formatearCueEnBloques(predioEscuela.cue); %>
                      <% if (cueBloques.length === 0) { %>
                        <span class="text-gray-400">-</span>
                      <% } else { %>
                        <% cueBloques.forEach((bloque) => { %>
                          <span class="whitespace-nowrap text-gray-900"><%= bloque %></span>
                        <% }) %>
                      <% } %>
                    </div>
                  </td>

                  <td class="px-2 py-2 font-semibold text-gray-900 overflow-hidden text-ellipsis whitespace-nowrap align-top">
                    <%= predioEscuela.nombreEscuela %>
                  </td>

                  <td class="px-2 py-2 overflow-hidden text-ellipsis whitespace-nowrap align-top">
                    <%= predioEscuela.direccion %>
                  </td>

                  <td class="px-2 py-2 overflow-hidden text-ellipsis whitespace-nowrap align-top">
                    <%= predioEscuela.ciudad %>
                  </td>

                  <td class="px-2 py-2 overflow-hidden text-ellipsis whitespace-nowrap align-top">
                    <%= predioEscuela.departamento %>
                  </td>

                  <td class="px-2 py-2 whitespace-nowrap text-center align-top">
                    <%= predioEscuela.megabytesAsignados %>
                  </td>

                  <td class="px-2 py-2 overflow-hidden text-ellipsis whitespace-nowrap align-top">
                    <%= predioEscuela.isp %>
                  </td>

                  <td class="px-2 py-2 overflow-hidden text-ellipsis whitespace-nowrap align-top">
                    <%= predioEscuela.tecnologia %>
                  </td>

                  <td class="px-2 py-2 whitespace-nowrap align-top">
                    <div class="flex flex-wrap items-center justify-center gap-1">
                      <a
                        href="/predios-escuelas/ver/<%= predioEscuela._id %>"
                        class="inline-flex items-center justify-center rounded-lg border border-blue-200 bg-blue-50 px-2 py-0.5 text-[9px] lg:text-[10px] font-semibold text-blue-700 hover:bg-blue-100 transition"
                      >
                        Ver
                      </a>

                      <a
                        href="/predios-escuelas/editar/<%= predioEscuela._id %>"
                        class="inline-flex items-center justify-center rounded-lg border border-amber-200 bg-amber-50 px-2 py-0.5 text-[9px] lg:text-[10px] font-semibold text-amber-700 hover:bg-amber-100 transition"
                      >
                        Editar
                      </a>

                      <form
                        action="/predios-escuelas/eliminar/<%= predioEscuela._id %>"
                        method="POST"
                        class="inline"
                        onsubmit="return confirm('¿Seguro que querés eliminar este registro?')"
                      >
                        <button
                          type="submit"
                          class="inline-flex items-center justify-center rounded-lg border border-red-200 bg-red-50 px-2 py-0.5 text-[9px] lg:text-[10px] font-semibold text-red-700 hover:bg-red-100 transition"
                        >
                          Eliminar
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- ===== MOBILE / CARDS ===== -->
    <div class="mt-3 grid grid-cols-1 gap-3 sm:hidden">
      <% if (!prediosSeguro || prediosSeguro.length === 0) { %>
        <article class="rounded-2xl border border-gray-200 bg-white p-4 shadow-sm">
          <p class="text-sm text-gray-500 text-center">No hay registros cargados.</p>
        </article>
      <% } else { %>
        <article id="sinResultadosMobile" class="hidden rounded-2xl border border-gray-200 bg-white p-4 shadow-sm">
          <p class="text-sm text-gray-500 text-center">No hay registros que coincidan con los filtros.</p>
        </article>

        <% prediosSeguro.forEach((predioEscuela, index) => { %>
          <%
            const textoBusquedaMobile = [
              predioEscuela.predio,
              predioEscuela.cue,
              predioEscuela.nombreEscuela,
              predioEscuela.direccion,
              predioEscuela.ciudad,
              predioEscuela.departamento,
              predioEscuela.megabytesAsignados,
              predioEscuela.isp,
              predioEscuela.tecnologia
            ].join(' ');
          %>

          <article
            class="card-predio rounded-2xl border border-gray-200 bg-white p-4 shadow-sm"
            data-search="<%= textoBusquedaMobile %>"
            data-departamento="<%= predioEscuela.departamento || '' %>"
            data-ciudad="<%= predioEscuela.ciudad || '' %>"
            data-isp="<%= predioEscuela.isp || '' %>"
            data-tecnologia="<%= predioEscuela.tecnologia || '' %>"
            data-mb="<%= predioEscuela.megabytesAsignados || 0 %>"
          >
            <div class="flex items-start justify-between gap-3">
              <div class="min-w-0">
                <p class="text-xs text-gray-500">Registro</p>
                <p class="numero-visible-mobile text-lg font-extrabold text-blue-800 leading-tight">#<%= index + 1 %></p>
                <p class="mt-1 text-sm font-semibold text-gray-900"><%= predioEscuela.nombreEscuela %></p>
                <p class="text-xs text-gray-600"><%= predioEscuela.ciudad %> · <%= predioEscuela.departamento %></p>
              </div>
            </div>

            <div class="mt-3 grid grid-cols-2 gap-2 text-xs text-gray-700">
              <div class="rounded-xl bg-gray-50 border border-gray-200 p-2">
                <p class="text-[11px] text-gray-500">Predio</p>
                <p class="font-semibold"><%= predioEscuela.predio %></p>
              </div>

              <div class="rounded-xl bg-gray-50 border border-gray-200 p-2">
                <p class="text-[11px] text-gray-500">CUE</p>
                <div class="mt-1 flex flex-col gap-0.5 leading-tight">
                  <% const cueBloquesMobile = formatearCueEnBloques(predioEscuela.cue); %>
                  <% if (cueBloquesMobile.length === 0) { %>
                    <span class="font-semibold text-gray-400">-</span>
                  <% } else { %>
                    <% cueBloquesMobile.forEach((bloque) => { %>
                      <span class="font-semibold"><%= bloque %></span>
                    <% }) %>
                  <% } %>
                </div>
              </div>

              <div class="rounded-xl bg-gray-50 border border-gray-200 p-2 col-span-2">
                <p class="text-[11px] text-gray-500">Escuela</p>
                <p class="font-semibold"><%= predioEscuela.nombreEscuela %></p>
              </div>

              <div class="rounded-xl bg-gray-50 border border-gray-200 p-2 col-span-2">
                <p class="text-[11px] text-gray-500">Dirección</p>
                <p class="font-semibold"><%= predioEscuela.direccion %></p>
              </div>

              <div class="rounded-xl bg-gray-50 border border-gray-200 p-2">
                <p class="text-[11px] text-gray-500">Ciudad</p>
                <p class="font-semibold"><%= predioEscuela.ciudad %></p>
              </div>

              <div class="rounded-xl bg-gray-50 border border-gray-200 p-2">
                <p class="text-[11px] text-gray-500">Departamento</p>
                <p class="font-semibold"><%= predioEscuela.departamento %></p>
              </div>

              <div class="rounded-xl bg-gray-50 border border-gray-200 p-2">
                <p class="text-[11px] text-gray-500">MB</p>
                <p class="font-semibold"><%= predioEscuela.megabytesAsignados %></p>
              </div>

              <div class="rounded-xl bg-gray-50 border border-gray-200 p-2">
                <p class="text-[11px] text-gray-500">ISP</p>
                <p class="font-semibold"><%= predioEscuela.isp %></p>
              </div>

              <div class="rounded-xl bg-gray-50 border border-gray-200 p-2 col-span-2">
                <p class="text-[11px] text-gray-500">Tecnología</p>
                <p class="font-semibold"><%= predioEscuela.tecnologia %></p>
              </div>
            </div>

            <div class="mt-3 flex flex-wrap gap-2">
              <a
                href="/predios-escuelas/ver/<%= predioEscuela._id %>"
                class="inline-flex items-center rounded-lg border border-blue-200 bg-blue-50 px-3 py-1.5 text-xs font-semibold text-blue-700 hover:bg-blue-100 transition"
              >
                Ver
              </a>

              <a
                href="/predios-escuelas/editar/<%= predioEscuela._id %>"
                class="inline-flex items-center rounded-lg border border-amber-200 bg-amber-50 px-3 py-1.5 text-xs font-semibold text-amber-700 hover:bg-amber-100 transition"
              >
                Editar
              </a>

              <form
                action="/predios-escuelas/eliminar/<%= predioEscuela._id %>"
                method="POST"
                class="inline"
                onsubmit="return confirm('¿Seguro que querés eliminar este registro?')"
              >
                <button
                  type="submit"
                  class="inline-flex items-center rounded-lg border border-red-200 bg-red-50 px-3 py-1.5 text-xs font-semibold text-red-700 hover:bg-red-100 transition"
                >
                  Eliminar
                </button>
              </form>
            </div>
          </article>
        <% }) %>
      <% } %>
    </div>

  </div>
</main>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const contador = document.getElementById('contadorFiltros');
    const totalRegistros = Number(contador?.dataset.total || 0);

    const inputBuscar = document.getElementById('filtroBuscar');
    const selectDepartamento = document.getElementById('filtroDepartamento');
    const selectCiudad = document.getElementById('filtroCiudad');
    const selectIsp = document.getElementById('filtroIsp');
    const selectTecnologia = document.getElementById('filtroTecnologia');
    const selectMb = document.getElementById('filtroMb');
    const btnLimpiar = document.getElementById('btnLimpiarFiltros');

    const filas = Array.from(document.querySelectorAll('.fila-predio'));
    const cards = Array.from(document.querySelectorAll('.card-predio'));

    const filaSinResultadosTabla = document.getElementById('filaSinResultadosTabla');
    const sinResultadosMobile = document.getElementById('sinResultadosMobile');

    const normalizar = (valor) => {
      return String(valor || '')
        .toLowerCase()
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '')
        .trim();
    };

    const coincideRegistro = (elemento) => {
      const buscar = normalizar(inputBuscar?.value);
      const departamento = normalizar(selectDepartamento?.value);
      const ciudad = normalizar(selectCiudad?.value);
      const isp = normalizar(selectIsp?.value);
      const tecnologia = normalizar(selectTecnologia?.value);
      const mb = String(selectMb?.value || '').trim();

      const dataSearch = normalizar(elemento.dataset.search);
      const dataDepartamento = normalizar(elemento.dataset.departamento);
      const dataCiudad = normalizar(elemento.dataset.ciudad);
      const dataIsp = normalizar(elemento.dataset.isp);
      const dataTecnologia = normalizar(elemento.dataset.tecnologia);
      const dataMb = String(elemento.dataset.mb || '').trim();

      const coincideBuscar = !buscar || dataSearch.includes(buscar);
      const coincideDepartamento = !departamento || dataDepartamento === departamento;
      const coincideCiudad = !ciudad || dataCiudad === ciudad;
      const coincideIsp = !isp || dataIsp === isp;
      const coincideTecnologia = !tecnologia || dataTecnologia === tecnologia;
      const coincideMb = !mb || dataMb === mb;

      return (
        coincideBuscar &&
        coincideDepartamento &&
        coincideCiudad &&
        coincideIsp &&
        coincideTecnologia &&
        coincideMb
      );
    };

    const actualizarNumeracion = () => {
      let contadorTabla = 0;

      filas.forEach((fila) => {
        if (!fila.classList.contains('hidden')) {
          contadorTabla++;
          const numero = fila.querySelector('.numero-visible');
          if (numero) numero.textContent = `#${contadorTabla}`;
        }
      });

      let contadorMobile = 0;

      cards.forEach((card) => {
        if (!card.classList.contains('hidden')) {
          contadorMobile++;
          const numero = card.querySelector('.numero-visible-mobile');
          if (numero) numero.textContent = `#${contadorMobile}`;
        }
      });
    };

    const aplicarFiltros = () => {
      let visiblesTabla = 0;
      let visiblesMobile = 0;

      filas.forEach((fila) => {
        const visible = coincideRegistro(fila);

        if (visible) {
          fila.classList.remove('hidden');
          visiblesTabla++;
        } else {
          fila.classList.add('hidden');
        }
      });

      cards.forEach((card) => {
        const visible = coincideRegistro(card);

        if (visible) {
          card.classList.remove('hidden');
          visiblesMobile++;
        } else {
          card.classList.add('hidden');
        }
      });

      if (filaSinResultadosTabla) {
        filaSinResultadosTabla.classList.toggle('hidden', visiblesTabla !== 0);
      }

      if (sinResultadosMobile) {
        sinResultadosMobile.classList.toggle('hidden', visiblesMobile !== 0);
      }

      const visibles = window.innerWidth < 640 ? visiblesMobile : visiblesTabla;

      if (contador) {
        contador.textContent = `Mostrando ${visibles} de ${totalRegistros}`;
      }

      actualizarNumeracion();
    };

    const limpiarFiltros = () => {
      if (inputBuscar) inputBuscar.value = '';
      if (selectDepartamento) selectDepartamento.value = '';
      if (selectCiudad) selectCiudad.value = '';
      if (selectIsp) selectIsp.value = '';
      if (selectTecnologia) selectTecnologia.value = '';
      if (selectMb) selectMb.value = '';

      aplicarFiltros();

      if (inputBuscar) inputBuscar.focus();
    };

    [
      inputBuscar,
      selectDepartamento,
      selectCiudad,
      selectIsp,
      selectTecnologia,
      selectMb,
    ].forEach((elemento) => {
      if (!elemento) return;

      elemento.addEventListener('input', aplicarFiltros);
      elemento.addEventListener('change', aplicarFiltros);
    });

    if (btnLimpiar) {
      btnLimpiar.addEventListener('click', limpiarFiltros);
    }

    window.addEventListener('resize', aplicarFiltros);

    aplicarFiltros();
  });
</script>