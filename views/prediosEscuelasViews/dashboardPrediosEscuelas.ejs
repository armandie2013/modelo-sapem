<div class="min-h-[calc(100vh-240px)] px-2 sm:px-4 py-2 sm:py-4 safe-bottom">
  <div class="mx-auto max-w-7xl">

    <div class="bg-white border border-gray-200 rounded-2xl shadow-xl overflow-hidden">
      <div class="px-4 sm:px-6 py-4 border-b border-gray-200 bg-gradient-to-r from-blue-50 via-white to-white">
        <div class="flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
          <div class="min-w-0">
            <h1 class="text-xl sm:text-2xl font-extrabold tracking-tight text-gray-900">
              Predios Escuelas
            </h1>
            <p class="mt-0.5 text-xs sm:text-sm text-gray-600">
              Listado general de predios y conectividad asignada.
            </p>
          </div>

          <div class="flex flex-col sm:flex-row gap-2">
            <a
              href="/predios-escuelas/crear"
              class="inline-flex items-center justify-center rounded-xl bg-blue-600 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-700 transition focus:outline-none focus:ring-2 focus:ring-blue-500/30"
            >
              Nuevo registro
            </a>
          </div>
        </div>
      </div>

      <div class="px-4 sm:px-6 py-4">
        <% if (mensaje) { %>
          <div class="mb-4 rounded-xl border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-800">
            <%= mensaje %>
          </div>
        <% } %>

        <div class="overflow-x-auto rounded-2xl border border-gray-200">
          <table class="min-w-full text-sm">
            <thead class="bg-gray-100 text-gray-700">
              <tr>
                <th class="px-3 py-3 text-left font-semibold">N°</th>
                <th class="px-3 py-3 text-left font-semibold">Predio</th>
                <th class="px-3 py-3 text-left font-semibold">CUE</th>
                <th class="px-3 py-3 text-left font-semibold">Escuela</th>
                <th class="px-3 py-3 text-left font-semibold">Dirección</th>
                <th class="px-3 py-3 text-left font-semibold">Ciudad</th>
                <th class="px-3 py-3 text-left font-semibold">Departamento</th>
                <th class="px-3 py-3 text-left font-semibold">MB</th>
                <th class="px-3 py-3 text-left font-semibold">ISP</th>
                <th class="px-3 py-3 text-left font-semibold">Tecnología</th>
                <th class="px-3 py-3 text-center font-semibold">Acciones</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-200 bg-white">
              <% if (prediosEscuelas.length === 0) { %>
                <tr>
                  <td colspan="11" class="px-4 py-6 text-center text-gray-500">
                    No hay registros cargados.
                  </td>
                </tr>
              <% } %>

              <% prediosEscuelas.forEach((predioEscuela, index) => { %>
                <tr class="hover:bg-gray-50">
                  <td class="px-3 py-3 font-medium text-gray-700"><%= index + 1 %></td>
                  <td class="px-3 py-3"><%= predioEscuela.predio %></td>
                  <td class="px-3 py-3"><%= predioEscuela.cue %></td>
                  <td class="px-3 py-3"><%= predioEscuela.nombreEscuela %></td>
                  <td class="px-3 py-3"><%= predioEscuela.direccion %></td>
                  <td class="px-3 py-3"><%= predioEscuela.ciudad %></td>
                  <td class="px-3 py-3"><%= predioEscuela.departamento %></td>
                  <td class="px-3 py-3"><%= predioEscuela.megabytesAsignados %></td>
                  <td class="px-3 py-3"><%= predioEscuela.isp %></td>
                  <td class="px-3 py-3"><%= predioEscuela.tecnologia %></td>
                  <td class="px-3 py-3">
                    <div class="flex items-center justify-center gap-2">
                      <a
                        href="/predios-escuelas/ver/<%= predioEscuela._id %>"
                        class="inline-flex items-center justify-center rounded-lg bg-slate-100 border border-slate-300 px-3 py-1.5 text-xs font-semibold text-slate-700 hover:bg-slate-200 transition"
                      >
                        Ver
                      </a>

                      <a
                        href="/predios-escuelas/editar/<%= predioEscuela._id %>"
                        class="inline-flex items-center justify-center rounded-lg bg-amber-100 border border-amber-300 px-3 py-1.5 text-xs font-semibold text-amber-700 hover:bg-amber-200 transition"
                      >
                        Editar
                      </a>

                      <form
                        action="/predios-escuelas/eliminar/<%= predioEscuela._id %>"
                        method="POST"
                        onsubmit="return confirm('¿Seguro que querés eliminar este registro?')"
                        class="inline"
                      >
                        <button
                          type="submit"
                          class="inline-flex items-center justify-center rounded-lg bg-red-100 border border-red-300 px-3 py-1.5 text-xs font-semibold text-red-700 hover:bg-red-200 transition"
                        >
                          Eliminar
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>