<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="utf-8" />
  <title>Estado del período — <%= proveedor?.nombreFantasia || proveedor?.nombreReal || '' %> — <%= periodo %></title>

  <style>
    * { box-sizing: border-box; }

    body {
      font-family: Arial, Helvetica, sans-serif;
      font-size: 12px;
      color: #111;
      margin: 0;
    }

    .wrap {
      max-width: 800px;
      margin: 0 auto;
      padding: 16px;
    }

    h1 { font-size: 18px; margin: 0; }
    h2 { font-size: 14px; margin: 16px 0 8px; }

    .muted { color: #666; }
    .small { font-size: 11px; color: #666; }
    .right { text-align: right; }

    .card {
      border: 1px solid #ddd;
      border-radius: 10px;
      padding: 12px;
      margin-bottom: 12px;
      background: #fff;
    }

    .headerCard {
      padding: 0;
      overflow: hidden;
    }

    .headerTopBar {
      height: 6px;
      background: linear-gradient(90deg, #2563eb, #06b6d4, #10b981);
    }

    .headerInner {
      padding: 12px;
    }

    .headerRow {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 12px;
    }

    .headerTitleBlock {
      min-width: 0;
    }

    .headerTitle {
      font-size: 18px;
      font-weight: 800;
      margin: 0;
      line-height: 1.15;
    }

    .headerSub {
      margin-top: 4px;
      color: #444;
      font-size: 13px;
      line-height: 1.25;
    }

    .metaGrid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 6px;
      text-align: right;
      min-width: 220px;
    }

    .metaLine {
      font-size: 11px;
      color: #374151;
    }

    .metaLine strong {
      color: #111;
    }

    .metaBig {
      font-size: 13px;
      color: #111;
      font-weight: 700;
    }

    .badge {
      display: inline-block;
      padding: 2px 6px;
      border-radius: 6px;
      font-size: 11px;
      background: #eef4ff;
      color: #143f7a;
      border: 1px solid #d7e3ff;
      white-space: nowrap;
    }

    .badgeBig {
      font-size: 12px;
      padding: 4px 10px;
      border-radius: 8px;
    }

    .totalsBox {
      margin-top: 8px;
      padding: 8px 10px;
      border: 1px solid #e5e7eb;
      border-radius: 10px;
      background: #fafafa;
      display: grid;
      gap: 4px;
    }

    .totLine {
      font-size: 11px;
      color: #374151;
    }

    .totLine b {
      font-size: 12px;
      color: #111;
    }

    .serviceLine {
      margin-top: 10px;
      font-size: 13px;
      color: #111;
      font-weight: 700;
    }

    .resumenGrid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 10px;
    }

    .miniCard {
      border: 1px solid #e5e7eb;
      border-radius: 10px;
      padding: 10px;
      background: #fafafa;
    }

    .miniLabel {
      font-size: 10px;
      color: #6b7280;
      margin-bottom: 4px;
      text-transform: uppercase;
    }

    .miniValue {
      font-size: 13px;
      font-weight: 300;
      color: #111;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      table-layout: fixed;
    }

    th,
    td {
      padding: 5px 6px;
      border-bottom: 1px solid #eee;
      text-align: left;
      vertical-align: top;
    }

    th {
      background: #f7f7f7;
      font-size: 10px;
    }

    td.right {
      white-space: nowrap;
    }

    .positivo {
      color: #b91c1c;
      font-weight: 700;
    }

    .negativo {
      color: #065f46;
      font-weight: 700;
    }

    /* =========================
       SOLO MOVIMIENTOS DEL PERÍODO
       ========================= */
    .movimientos-periodo-table {
      width: 100%;
      border-collapse: collapse;
      table-layout: fixed;
    }

    .movimientos-periodo-table th,
    .movimientos-periodo-table td {
      font-size: 9px;
      padding: 4px 5px;
      line-height: 1.15;
      border-bottom: 1px solid #eee;
      text-align: left;
      vertical-align: top;
    }

    .movimientos-periodo-table th {
      background: #f7f7f7;
      font-size: 8.5px;
    }

    .mov-col-fecha {
      width: 78px;
      min-width: 78px;
      white-space: nowrap;
    }

    .mov-col-tipo {
      width: 86px;
      min-width: 86px;
      white-space: normal;
      line-height: 1.1;
    }

    .mov-col-concepto {
      width: 230px;
      min-width: 230px;
      white-space: normal;
      overflow-wrap: anywhere;
      line-height: 1.12;
    }

    .mov-col-metodo {
      width: 72px;
      min-width: 72px;
      white-space: normal;
    }

    .mov-col-comprobante {
      width: 86px;
      min-width: 86px;
      white-space: normal;
      overflow-wrap: anywhere;
    }

    .mov-col-importe {
      width: 78px;
      min-width: 78px;
      white-space: nowrap;
      text-align: right;
      padding-right: 5px;
      padding-left: 5px;
    }

    .movimientos-periodo-table td.mov-col-importe,
    .movimientos-periodo-table th.mov-col-importe {
      text-align: right;
    }

    .mov-total-row td {
      border-top: 1px solid #ddd;
      border-bottom: none;
      padding-top: 10px;
      font-weight: 700;
      background: #fff;
      font-size: 11px;
    }
  </style>
</head>

<body>

  <header style="margin-top: 0px; margin-bottom: 20px;">
    <% if (typeof logoDataUri !== 'undefined' && logoDataUri) { %>
      <div style="text-align:center; margin-bottom:8px;">
        <img src="<%= logoDataUri %>" alt="Logo" style="max-height:75px; display:inline-block;" />
      </div>
    <% } %>
  </header>

  <div class="wrap">
    <%
      const fmtUSD = v =>
        new Intl.NumberFormat('es-AR', {
          style: 'currency',
          currency: 'USD',
          minimumFractionDigits: 2,
          maximumFractionDigits: 2
        }).format(Number(v || 0));

      const fmtARS = v =>
        new Intl.NumberFormat('es-AR', {
          style: 'currency',
          currency: 'ARS',
          minimumFractionDigits: 2,
          maximumFractionDigits: 2
        }).format(Number(v || 0));

      const tc = Number(usdAyer?.tipoCotizacion || 0);

      function fmtFecha(v) {
        if (!v) return '—';
        try {
          return new Date(v).toLocaleDateString('es-AR');
        } catch {
          return '—';
        }
      }

      function fmtFechaISOaDMY(iso) {
        try {
          return new Intl.DateTimeFormat('es-AR', { day: '2-digit', month: '2-digit', year: 'numeric' })
            .format(new Date(String(iso) + 'T00:00:00'));
        } catch { return iso || ''; }
      }

      function truncarConceptoMovimiento(txt, tipo) {
        let s = String(txt || '').trim();
        const t = String(tipo || '').toLowerCase();

        if (!s) return '—';

        if (t === 'cargo') {
          s = s.replace(/\d{4}-\d{2}/g, '').trim();

          const match = s.match(/[A-ZÁÉÍÓÚÑ0-9][A-ZÁÉÍÓÚÑ0-9\s.\-\/]+/);
          if (match) {
            s = match[0];
          }

          s = s.replace(/\s{2,}/g, ' ').trim();
          return s || 'Cargo';
        }

        return s;
      }

      const fechaTC = usdAyer?.fecha ? fmtFechaISOaDMY(usdAyer.fecha) : null;

      const proveedorDisplay = proveedor?.nombreFantasia || proveedor?.nombreReal || '—';
      const proveedorLegal = proveedor?.nombreReal || '—';
      const provCuit = proveedor?.cuit || '—';
      const provIva = proveedor?.condicionIva || '—';
      const provTel = proveedor?.telefonoCelular || '—';
      const fechaReporte = hoy ? new Date(hoy).toLocaleDateString('es-AR') : '';
      const servicio = servicioActual || 'Servicio mensual';
    %>

    <div class="card headerCard">
      <div class="headerTopBar"></div>

      <div class="headerInner">
        <div class="headerRow">
          <div class="headerTitleBlock">
            <h1 class="headerTitle">Estado del período</h1>

            <div class="headerSub">
              <div style="margin-bottom:4px;">
                Proveedor: <strong><%= proveedorDisplay %></strong>
              </div>

              <div class="headerSub">
                Nombre legal: <strong><%= proveedorLegal %></strong>
              </div>

              <div class="small muted" style="margin-top:4px;">
                CUIT:
                <span style="font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace;"><%= provCuit %></span>
                · IVA: <%= provIva %>
                · Tel: <%= provTel %>
              </div>

              <div class="serviceLine">
                Servicio: <%= servicio %>
              </div>

              <div class="serviceLine">
                Período: <%= periodo %>
              </div>
            </div>
          </div>

          <div class="metaGrid">
            <div class="metaLine metaBig">
              Fecha reporte: <%= fechaReporte %>
            </div>

            <div class="metaLine">
              <% if (tc > 0) { %>
                <span class="badge badgeBig">
                  USD: <strong>
                    <%= new Intl.NumberFormat('es-AR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(tc) %>
                  </strong>
                  <%= fechaTC ? ` · ${fechaTC}` : '' %>
                </span>
              <% } else { %>
                <span class="small muted">TC de ayer no disponible</span>
              <% } %>
            </div>

            <div class="totalsBox">
              <div class="totLine">
                Total del período (USD): <b><%= fmtUSD(totales?.saldo || 0) %></b>
              </div>
              <% if (tc > 0) { %>
                <div class="totLine">
                  Total del período (ARS): <b><%= fmtARS((totales?.saldo || 0) * tc) %></b>
                </div>
              <% } %>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="card">
      <h2>Resumen del período</h2>

      <div class="resumenGrid">
        <div class="miniCard">
          <div class="miniLabel">Cargo base</div>
          <div class="miniValue"><%= fmtUSD(totales?.cargo || 0) %></div>
        </div>

        <div class="miniCard">
          <div class="miniLabel">Notas débito</div>
          <div class="miniValue"><%= fmtUSD(totales?.notaDebito || 0) %></div>
        </div>

        <div class="miniCard">
          <div class="miniLabel">Notas crédito</div>
          <div class="miniValue"><%= fmtUSD(totales?.notaCredito || 0) %></div>
        </div>

        <div class="miniCard">
          <div class="miniLabel">Pagos</div>
          <div class="miniValue"><%= fmtUSD(totales?.pagos || 0) %></div>
        </div>

        <div class="miniCard">
          <div class="miniLabel">Total a pagar</div>
          <div class="miniValue"><%= fmtUSD(totales?.saldo || 0) %></div>
        </div>
      </div>
    </div>

    <div class="card">
      <h2>Movimientos del período</h2>

      <table class="movimientos-periodo-table">
        <thead>
          <tr>
            <th class="mov-col-fecha">Fecha</th>
            <th class="mov-col-tipo">Tipo</th>
            <th class="mov-col-concepto">Concepto</th>
            <th class="mov-col-metodo">Método</th>
            <th class="mov-col-comprobante">Comprobante</th>
            <th class="mov-col-importe">Importe</th>
          </tr>
        </thead>
        <tbody>
          <% if (!movimientos || movimientos.length === 0) { %>
            <tr>
              <td colspan="6" class="small muted">Sin movimientos para este período.</td>
            </tr>
          <% } else { %>
            <% movimientos.forEach(m => { %>
              <tr>
                <td class="mov-col-fecha"><%= fmtFecha(m.fecha) %></td>
                <td class="mov-col-tipo"><%= m.tipo || '—' %></td>
                <td class="mov-col-concepto"><%= truncarConceptoMovimiento(m.concepto || '', m.tipo || '') %></td>
                <td class="mov-col-metodo"><%= m.metodo || '—' %></td>
                <td class="mov-col-comprobante"><%= m.comprobante || '—' %></td>
                <td class="mov-col-importe <%= m.signo === '+' ? 'positivo' : 'negativo' %>">
                  <%= m.signo === '+' ? '+' : '-' %> <%= fmtUSD(m.importe || 0) %>
                </td>
              </tr>
            <% }) %>

            <tr class="mov-total-row">
  <td colspan="6" style="text-align: right;" class="miniValue">
    Total a pagar: 
    <span style="margin-left: 10px;">
      <%= fmtUSD(totales?.saldo || 0) %>
    </span>
  </td>
</tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <div class="small muted">
      * Este reporte detalla todos los movimientos que componen el saldo del período seleccionado.
    </div>
  </div>
</body>

</html>