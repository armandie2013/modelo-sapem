<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="utf-8" />
  <title>Estado de cuenta — <%= (proveedor?.nombreFantasia || proveedor?.nombreReal || '') %></title>

  <style>
    * { box-sizing: border-box; }

    body {
      font-family: Arial, Helvetica, sans-serif;
      font-size: 12px;
      color: #111;
      margin: 0;
    }

    .wrap {
      max-width: 800px;
      margin: 0 auto;
      padding: 16px;
    }

    h1 { font-size: 18px; margin: 0; }
    h2 { font-size: 14px; margin: 16px 0 8px; }

    .muted { color: #666; }
    .small { font-size: 11px; }
    .right { text-align: right; }

    .card {
      border: 1px solid #ddd;
      border-radius: 10px;
      padding: 12px;
      margin-bottom: 12px;
      background: #fff;
    }

    .grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }

    .totals { font-weight: 700; }

    .badge {
      display: inline-block;
      padding: 2px 6px;
      border-radius: 6px;
      font-size: 11px;
      background: #eef4ff;
      color: #143f7a;
      border: 1px solid #d7e3ff;
      white-space: nowrap;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      table-layout: fixed;
    }

    th,
    td {
      padding: 5px 6px;
      border-bottom: 1px solid #eee;
      text-align: left;
      vertical-align: top;
    }

    th {
      background: #f7f7f7;
      font-size: 10px;
    }

    td.right {
      white-space: nowrap;
    }

    .headerCard {
      padding: 0;
      overflow: hidden;
    }

    .headerTopBar {
      height: 6px;
      background: linear-gradient(90deg, #2563eb, #06b6d4, #10b981);
    }

    .headerInner {
      padding: 12px;
    }

    .headerRow {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 12px;
    }

    .headerTitleBlock {
      min-width: 0;
    }

    .headerTitle {
      font-size: 18px;
      font-weight: 800;
      margin: 0;
      line-height: 1.15;
    }

    .headerSub {
      margin-top: 4px;
      color: #444;
      font-size: 13px;
      line-height: 1.25;
    }

    .metaGrid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 6px;
      text-align: right;
      min-width: 220px;
    }

    .metaLine {
      font-size: 11px;
      color: #374151;
    }

    .metaLine strong {
      color: #111;
    }

    .metaBig {
      font-size: 13px;
      color: #111;
      font-weight: 700;
    }

    .badgeBig {
      font-size: 12px;
      padding: 4px 10px;
      border-radius: 8px;
    }

    .totalsBox {
      margin-top: 8px;
      padding: 8px 10px;
      border: 1px solid #e5e7eb;
      border-radius: 10px;
      background: #fafafa;
      display: grid;
      gap: 4px;
    }

    .totLine {
      font-size: 11px;
      color: #374151;
    }

    .totLine b {
      font-size: 12px;
      color: #111;
    }

    .serviceLine {
      margin-top: 10px;
      font-size: 13px;
      color: #111;
      font-weight: 700;
    }

    .totalesSimple td {
      border-top: 1px solid #ddd;
      border-bottom: none;
      padding-top: 9px;
      font-weight: 700;
      background: #fff;
    }

    .tabla-periodos th,
    .tabla-periodos td {
      font-size: 10px;
      padding: 5px 5px;
    }

    .col-periodo {
      width: 58px;
      min-width: 58px;
      white-space: nowrap;
    }

    .col-concepto {
      width: 140px;
      white-space: normal;
      overflow-wrap: anywhere;
      line-height: 1.15;
    }

    .col-money {
      width: 68px;
      min-width: 68px;
      white-space: nowrap;
    }
  </style>
</head>

<body>

  <header style="margin-top: 0px; margin-bottom: 20px;">
    <% if (typeof logoDataUri !== 'undefined' && logoDataUri) { %>
      <div style="text-align:center; margin-bottom:8px;">
        <img src="<%= logoDataUri %>" alt="Logo" style="max-height:75px; display:inline-block;" />
      </div>
    <% } %>
  </header>

  <div class="wrap">
    <%
      const fmtUSD = v =>
        new Intl.NumberFormat('es-AR', {
          style: 'currency',
          currency: 'USD',
          minimumFractionDigits: 2,
          maximumFractionDigits: 2
        }).format(Number(v || 0));

      const fmtARS = v =>
        new Intl.NumberFormat('es-AR', {
          style: 'currency',
          currency: 'ARS',
          minimumFractionDigits: 2,
          maximumFractionDigits: 2
        }).format(Number(v || 0));

      const tc = Number(usdAyer?.tipoCotizacion || 0);

      function fmtFechaISOaDMY(iso) {
        try {
          return new Intl.DateTimeFormat('es-AR', { day: '2-digit', month: '2-digit', year: 'numeric' })
            .format(new Date(String(iso) + 'T00:00:00'));
        } catch { return iso || ''; }
      }

      const fechaTC = usdAyer?.fecha ? fmtFechaISOaDMY(usdAyer.fecha) : null;

      function limpiarServicioCompleto(txt) {
        return String(txt || '')
          .replace(/\d{4}-\d{2}/g, '')
          .replace(/\bcargo\b/gi, '')
          .replace(/\bmensual\b/gi, '')
          .replace(/\bplan\b/gi, '')
          .replace(/\s{2,}/g, ' ')
          .trim() || 'Servicio mensual';
      }

      function truncarConcepto(txt) {
        const s = String(txt || '').toUpperCase().trim();

        if (!s) return 'Servicio mensual';

        const matchVel = s.match(/(\d+)\s*MBPS/);

        if (s.includes('INTERNET') && s.includes('DEDICADO')) {
          const velocidad = matchVel ? matchVel[1] : '';
          return velocidad ? `INT. DED. ${velocidad} MBPS` : 'INT. DED.';
        }

        if (s.includes('CARGO')) {
          return 'Cargo mensual';
        }

        return s
          .replace(/\d{4}-\d{2}/g, '')
          .replace(/\bCARGO\b/gi, '')
          .replace(/\bMENSUAL\b/gi, '')
          .replace(/\bPLAN\b/gi, '')
          .replace(/\s{2,}/g, ' ')
          .trim() || 'Servicio mensual';
      }

      const proveedorDisplay = (proveedor?.nombreFantasia || proveedor?.nombreReal || '—');
      const proveedorLegal   = (proveedor?.nombreReal || '—');
      const provCuit         = (proveedor?.cuit || '—');
      const provIva          = (proveedor?.condicionIva || '—');
      const provTel          = (proveedor?.telefonoCelular || '—');
      const fechaReporte     = (hoy ? new Date(hoy).toLocaleDateString('es-AR') : '');

      const pendientesOrdenados = [...(pendientes || [])].sort((a, b) =>
        String(b.periodo || '').localeCompare(String(a.periodo || ''))
      );

      const servicioCompleto = limpiarServicioCompleto(servicioActual || '');
    %>

    <!-- Header -->
    <div class="card headerCard">
      <div class="headerTopBar"></div>

      <div class="headerInner">
        <div class="headerRow">
          <div class="headerTitleBlock">
            <h1 class="headerTitle">Estado de cuenta</h1>

            <div class="headerSub">
              <div style="margin-bottom:4px;">
                Proveedor: <strong><%= proveedorDisplay %></strong>
              </div>

              <div class="headerSub">
                Nombre legal: <strong><%= proveedorLegal %></strong>
              </div>

              <div class="small muted" style="margin-top:4px;">
                CUIT:
                <span style="font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace;"><%= provCuit %></span>
                · IVA: <%= provIva %>
                · Tel: <%= provTel %>
              </div>

              <div class="serviceLine">
                Servicio: <%= servicioCompleto %>
              </div>
            </div>
          </div>

          <div class="metaGrid">
            <div class="metaLine metaBig">
              Fecha reporte: <%= fechaReporte %>
            </div>

            <div class="metaLine">
              <% if (tc > 0) { %>
                <span class="badge badgeBig">
                  USD: <strong>
                    <%= new Intl.NumberFormat('es-AR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(tc) %>
                  </strong>
                  <%= fechaTC ? ` · ${fechaTC}` : '' %>
                </span>
              <% } else { %>
                <span class="small muted">TC de ayer no disponible</span>
              <% } %>
            </div>

            <div class="totalsBox">
              <div class="totLine">
                Total pendiente (USD): <b><%= fmtUSD(totalPendiente || 0) %></b>
              </div>
              <% if (tc > 0) { %>
                <div class="totLine">
                  Total pendiente (ARS): <b><%= fmtARS((totalPendiente || 0) * tc) %></b>
                </div>
              <% } %>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Último pago -->
    <div class="card">
      <h2>Último pago registrado</h2>

      <% if (!ultimoPago) { %>
        <div class="small muted">No hay pagos registrados para el período.</div>
      <% } else { const _f = ultimoPago.fecha || ultimoPago.createdAt; %>
        <table>
          <thead>
            <tr>
              <th class="col-periodo">Período</th>
              <th>Fecha</th>
              <th>Método</th>
              <th>Comprobante</th>
              <th class="right col-money">Importe</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="col-periodo"><strong><%= ultimoPago.periodo || '—' %></strong></td>
              <td><%= _f ? new Date(_f).toLocaleDateString('es-AR') : '—' %></td>
              <td><%= ultimoPago.metodo || '—' %></td>
              <td><%= ultimoPago.comprobante || '—' %></td>
              <td class="right col-money"><%= fmtUSD(ultimoPago.importe || 0) %></td>
            </tr>
          </tbody>
        </table>
      <% } %>
    </div>

    <!-- Períodos adeudados -->
    <div class="card">
      <h2>Períodos adeudados</h2>

      <table class="tabla-periodos">
        <thead>
          <tr>
            <th class="col-periodo">Período</th>
            <th class="col-concepto">Concepto</th>
            <th class="right col-money">Cargo base</th>
            <th class="right col-money">Débitos</th>
            <th class="right col-money">Créditos</th>
            <th class="right col-money">Pagos</th>
            <th class="right col-money">Saldo</th>
          </tr>
        </thead>

        <tbody>
          <% if (!pendientesOrdenados.length) { %>
            <tr>
              <td colspan="7" class="small muted">Sin períodos vencidos con saldo pendiente.</td>
            </tr>
          <% } else { %>
            <% pendientesOrdenados.forEach(p => { %>
              <tr>
                <td class="col-periodo"><strong><%= p.periodo %></strong></td>
                <td class="col-concepto"><%= truncarConcepto(p.concepto || '') %></td>
                <td class="right col-money"><%= fmtUSD(p.importe || 0) %></td>
                <td class="right col-money"><%= fmtUSD(p.debitos || 0) %></td>
                <td class="right col-money"><%= fmtUSD(p.creditos || 0) %></td>
                <td class="right col-money"><%= fmtUSD(p.pagado || 0) %></td>
                <td class="right col-money"><strong><%= fmtUSD(p.saldo || 0) %></strong></td>
              </tr>
            <% }) %>

            <tr class="totalesSimple">
              <td colspan="6" class="right"><strong>Totales:</strong></td>
              <td class="right col-money"><strong><%= fmtUSD(totalPendiente || 0) %></strong></td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <!-- Totales -->
    <div class="card">
      <div class="grid">
        <div></div>
        <div class="right">
          <div class="totals">Total pendiente (USD): <%= fmtUSD(totalPendiente || 0) %></div>
          <% if (tc > 0) { %>
            <div class="totals">Total pendiente (ARS): <%= fmtARS((totalPendiente || 0) * tc) %></div>
          <% } %>
        </div>
      </div>
    </div>

    <div class="small muted">
      * La cotización informada corresponde al día del reporte. Para obtener la cotización vigente, comuníquese al 03834-017741.
    </div>
  </div>
</body>

</html>